# ────────────────────────────────────────────────
# GAS OS Environment Variables — TEMPLATE
# Copy this to .env and fill in real values
# DO NOT commit .env to git
# ────────────────────────────────────────────────

# Required: Random 64-char hex for session signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-64-char-hex-string

# Required: Shop key (any random string, used for legacy auth)
SHOP_KEY=chaipenn1988secret

# Database path
# Local: gasshop.db
# Railway: /data/gasshop.db (with mounted volume)
DATABASE_PATH=gasshop.db

# Server port (Railway sets this automatically)
PORT=5000

# Debug mode — set to 1 for local dev only, NEVER in production
FLASK_DEBUG=0

# Optional: LINE Notify tokens for alerts
LINE_NOTIFY_TOKEN=
LINE_NOTIFY_TOKEN_STOCK=

# Optional: SlipOK API for auto-verify transfer slips
SLIPOK_KEY=

# Optional: Google Sheets webhook for sync
SHEETS_WEBHOOK=
